@baseUrl = http://localhost:3000/api/v1
@content-type = application/json


### create a new user
# @name registerUser
POST {{baseUrl}}/auth/register
Content-Type:{{content-type}}

{
    "email":"muhammad.ahmad.raza789@gmail.com",
    "username":"AhmadRaza",
    "password":"Fake123*"
}


### login 
# @name login
POST {{baseUrl}}/auth/login
Content-Type:{{content-type}}

{
    "email":"muhammad.ahmad.raza789@gmail.com",
    "password":"FakeFate123*"
}


### change password 
# @name change-password
PATCH  {{baseUrl}}/auth/change-password
Content-Type:{{content-type}}

{
      "password":"Fake123*",
      "newPassword":"FakeFate123*"
}

### forgot Password
# @name forgotPassword
POST  {{baseUrl}}/auth/forgot-password
Content-Type:{{content-type}}

{
    "email":"muhammad.ahmad.raza789@gmail.com"
}



### verify password rests token
# @name verify-password-resets
GET {{baseUrl}}/auth/password-resets/be154b713412bf166667be57c9ae676730a29dc77e1f7dbae6fcadcc05905d2f
Content-Type:{{content-type}}


### resets Password
# @name password-rests
PATCH {{baseUrl}}/auth/password-resets/be154b713412bf166667be57c9ae676730a29dc77e1f7dbae6fcadcc05905d2f
Content-Type:{{content-type}}

{
     "password":"FakeFate123*"
}


### send user verification email
# @name sendVerificationEmail

POST {{baseUrl}}/auth/email-verification

### verify user email
# @name verifyEmail
PATCH {{baseUrl}}/auth/email-verification/27d0402957a37987425f70cf392262788322cbfb7e111e1918d19d51a7c58e2d