@baseUrl = http://localhost:3000/api/v1
@content-type = application/json


### create a new user
# @name registerUser
POST {{baseUrl}}/auth/register
Content-Type:{{content-type}}

{
    "email":"muhammada.ahmad.raza789@gmail.com",
    "username":"AhmadRaza",
    "password":"Fake123*"
}


### login 
# @name login
POST {{baseUrl}}/auth/login
Content-Type:{{content-type}}

{
    "email":"muhammad.ahmad.raza789@gmail.com",
    "password":"Fake123*"
}


### change password 
# @name change-password
PATCH  {{baseUrl}}/auth/change-password
Content-Type:{{content-type}}

{
      "password":"Fake123*",
      "newPassword":"Fake123*"
}

### forgot Password
# @name forgotPassword
POST  {{baseUrl}}/auth/forgot-password
Content-Type:{{content-type}}

{
    "email":"muhammad.ahmad.raza789@gmail.com"
}



### verify password rests token
# @name verify-password-resets
GET {{baseUrl}}/auth/password-resets/be154b713412bf166667be57c9ae676730a29dc77e1f7dbae6fcadcc05905d2f
Content-Type:{{content-type}}


### resets Password
# @name password-rests
PATCH {{baseUrl}}/auth/password-resets/be154b713412bf166667be57c9ae676730a29dc77e1f7dbae6fcadcc05905d2f
Content-Type:{{content-type}}
{
     "password":"FakeFate123*"
}


### send user verification email
# @name sendVerificationEmail

POST {{baseUrl}}/auth/email-verification

### verify user email
# @name verifyEmail
PATCH {{baseUrl}}/auth/email-verification/7a290ca9c812606117a64a434fe2cc34bd93bea2c928087650bcb93d0cd71698


### refreshToken
# @name refreshToken

POST  {{baseUrl}}/auth/refresh-token


### logout
# @name logout

Post {{baseUrl}}/auth/logout


# publications

###
# create Publications
# @name createPublications
Post {{baseUrl}}/publications
Content-Type:{{content-type}}

{
     "name":"Wild Guess",
     "description":"just a wild guess"
}

###
# get Publications
# @name getPublications
GET {{baseUrl}}/publications/Wild-Guess
Content-Type:{{content-type}}


###
# update Publications
# @name updatePublications
PATCH {{baseUrl}}/publications/813ea03a-f484-4982-b651-46d5fbb5cae8
Content-Type:{{content-type}}

{
     "description":"whats up brother ite me marios"
}

###
# @name getAllVersionsOfPublciations
GET {{baseUrl}}/publications/813ea03a-f484-4982-b651-46d5fbb5cae8/versions
Content-Type:{{content-type}}



### rollback to one of the previous version 
# @name getAllVersionsOfPublciations
PATCH {{baseUrl}}/publications/813ea03a-f484-4982-b651-46d5fbb5cae8/versions/1ef779ff-ffef-486f-8370-a466591e2e21
Content-Type:{{content-type}}

