@baseUrl = http://localhost:3000/api/v1
@content-type = application/json


### create a new user
# @name registerUser
POST {{baseUrl}}/auth/register
Content-Type:{{content-type}}

{
    "email":"fake1@fake.com",
    "username":"AhmadRaza",
    "password":"Fake123*"
}


### login 
# @name login
POST {{baseUrl}}/auth/login
Content-Type:{{content-type}}

{
    "email":"fake1@fake.com",
    "password":"FakeFate123*"
}


### change password 
# @name change-password
PATCH  {{baseUrl}}/auth/change-password
Content-Type:{{content-type}}

{
      "password":"Fake123*",
      "newPassword":"FakeFate123*"
}

### forgot Password
# @name forgotPassword
POST  {{baseUrl}}/auth/forgot-password
Content-Type:{{content-type}}

{
    "email":"fake1@fake.com"
}

### setting restsPasswordUrl
 @passwordRestsUrls = {{forgotPassword.response.body.passwordResetUrl}}

### resets Password
# @name password-rests
PATCH {{passwordRestsUrls}}
Content-Type:{{content-type}}

{
     "password":"Fate123*"
}